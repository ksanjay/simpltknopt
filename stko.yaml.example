# stko.yaml — project-level config
# Copy this to stko.yaml in your project root, then customize.
# Check into version control. Do NOT store raw API keys here — use ${ENV_VAR}.

api_keys:
  anthropic: ${ANTHROPIC_API_KEY}
  openai: ${OPENAI_API_KEY}
  google: ${GOOGLE_API_KEY}
  deepseek: ${DEEPSEEK_API_KEY}

defaults:
  quality_threshold: 0.75       # global default; overridable per run (--threshold) or per SubTask
  verify: false                 # verification is opt-in; set true here to enable globally
  max_escalations: 2            # retries with next-best model when verification fails
  decomposition_model: claude-haiku-4-5-20251001
  judge_model: auto             # "auto" = cheapest model with classification >= 0.80
  interactive: true             # show plan table and prompt before executing
  on_quality_failure: continue  # "continue" or "raise"

# Registry fetched from this URL on startup (ETag-cached locally)
registry_url: https://registry.simpltknopt.dev/models.yaml

# Restrict to specific providers (e.g. data residency requirements)
enabled_providers:
  - anthropic
  - openai
  - google
  - deepseek

# Override capability scores or add custom models on top of the fetched registry
# registry_overrides:
#   - id: deepseek/deepseek-chat
#     capabilities:
#       code_generation: 0.93   # you've validated this for your codebase
